10. Real Project Implementation - Framework Integration (Java + Selenium + SOAP)
10.1 Java‑Based SOAP Client Example (JAX‑WS)
java
import javax.xml.soap.*;
public class SOAPClient {
    public static void main(String[] args) throws Exception {
        SOAPConnectionFactory factory = SOAPConnectionFactory.newInstance();
        SOAPConnection connection = factory.createConnection();
        
        MessageFactory messageFactory = MessageFactory.newInstance();
        SOAPMessage message = messageFactory.createMessage();
        SOAPEnvelope envelope = message.getSOAPPart().getEnvelope();
        SOAPBody body = envelope.getBody();
        
        SOAPElement operation = body.addChildElement(
            envelope.createName("GetAddress", "ns", "http://maps.example.com/"));
        operation.addChildElement("Latitude").addTextNode("40.7128");
        operation.addChildElement("Longitude").addTextNode("-74.0060");
        
        SOAPMessage response = connection.call(message, "http://soap.service.com/endpoint");
        String responseString = response.getSOAPBody().getTextContent();
        // Extract using XPath or DOM parser
    }
}

