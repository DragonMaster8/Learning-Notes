7. API Chaining (End-to-End Flow)

Objective: Add → Update → Get → Validate

text
Step 1: Add Place (POST)
    ↓
Step 2: Extract place_id from response
    ↓
Step 3: Update Place (PUT) using extracted place_id
    ↓
Step 4: Get Place (GET) using same place_id
    ↓
Step 5: Validate address was updated correctly

Complete Implementation

java
public class EndToEndTest {
    @Test
    public void addUpdateGetPlace() {
        // Step 1: Add Place
        String addResponse = given()
            .queryParam("key", "qaclick123")
            .header("Content-Type", "application/json")
            .body(payload.AddPlace())
        .when()
            .post("maps/api/place/add/json")
        .then()
            .statusCode(200)
            .extract().asString();
        
        // Step 2: Extract place_id
        JsonPath js = new JsonPath(addResponse);
        String placeId = js.getString("place_id");
        
        // Step 3: Update Place with new address
        String newAddress = "70 Summer walk, USA";
        String updateBody = "{\n" +
            "\"place_id\": \"" + placeId + "\",\n" +
            "\"address\": \"" + newAddress + "\",\n" +
            "\"key\": \"qaclick123\"\n" +
            "}";
        
        given()
            .queryParam("key", "qaclick123")
            .header("Content-Type", "application/json")
            .body(updateBody)
        .when()
            .put("maps/api/place/update/json")
        .then()
            .statusCode(200)
            .body("msg", equalTo("Address successfully updated"));
        
        // Step 4: Get Place and validate address
        String getResponse = given()
            .queryParam("key", "qaclick123")
            .queryParam("place_id", placeId)
        .when()
            .get("maps/api/place/get/json")
        .then()
            .statusCode(200)
            .extract().asString();
        
        // Step 5: Validate address
        JsonPath jsGet = new JsonPath(getResponse);
        String actualAddress = jsGet.getString("address");
        
        Assert.assertEquals(actualAddress, newAddress);
    }
}

