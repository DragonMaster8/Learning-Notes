Create Issue (Bug) — Complete Code
java

import static io.restassured.RestAssured.*;
import io.restassured.path.json.JsonPath;
public class JiraBugTest {
    public static void main(String[] args) {
        baseURI = "https://your-domain.atlassian.net/";
        
        // 1. Create Issue
        String createResponse = given()
            .header("Content-Type", "application/json")
            .header("Authorization", "Basic " + base64EncodedToken)
            .body("{\n" +
                  "    \"fields\": {\n" +
                  "        \"project\": {\"key\": \"SCRUM\"},\n" +
                  "        \"summary\": \"Button not working - automation\",\n" +
                  "        \"issuetype\": {\"name\": \"Bug\"}\n" +
                  "    }\n" +
                  "}")
            .post("rest/api/3/issue")
            .then().assertThat().statusCode(201)
            .extract().response().asString();
        
        JsonPath js = new JsonPath(createResponse);
        String issueId = js.getString("id");
        System.out.println("Created Issue ID: " + issueId);
        
        // 2. Add Attachment
        given()
            .pathParam("key", issueId)
            .header("X-Atlassian-Token", "no-check")
            .header("Authorization", "Basic " + base64EncodedToken)
            .multiPart("file", new File("C:\\screenshot.png"))
            .post("rest/api/3/issue/{key}/attachments")
            .then().assertThat().statusCode(200);
    }
}
