12. Sum Validation & Business Logic Testing

Objective

Verify that total purchase amount equals sum of (price × copies) for all courses.
Formula

text
Σ(price × copies) = purchaseAmount

Implementation

java
import org.testng.annotations.Test;
import org.testng.Assert;
import io.restassured.path.json.JsonPath;
import files.payload;
public class SumValidation {
    
    @Test
    public void sumOfCourses() {
        // Get JSON response (mocked or from API)
        String response = payload.ComplexJson();
        JsonPath js = new JsonPath(response);
        
        // Get purchase amount from dashboard
        int purchaseAmount = js.getInt("dashboard.purchaseAmount");
        
        // Get course count
        int courseCount = js.getInt("courses.size()");
        
        // Calculate sum of all (price × copies)
        int totalSum = 0;
        for (int i = 0; i < courseCount; i++) {
            int price = js.getInt("courses[" + i + "].price");
            int copies = js.getInt("courses[" + i + "].copies");
            int amount = price * copies;
            totalSum = totalSum + amount;
        }
        
        System.out.println("Calculated Total: " + totalSum);
        System.out.println("Purchase Amount: " + purchaseAmount);
        
        // Assertion
        Assert.assertEquals(totalSum, purchaseAmount, "Sum mismatch!");
    }
}

