Section 10: Troubleshooting Common Issues

Issue 1: "invalid_grant" Error

Symptoms:
Token exchange fails with 400 error

Error description: "Code already redeemed"

Root Cause:
Authorization code already used

Code expired (usually 10 minutes lifetime)

Solution:
javascript
// Add retry logic for code exchange
let retryCount = 0;
const maxRetries = 3;
function exchangeCodeWithRetry(code) {
  if (retryCount >= maxRetries) {
    throw new Error("Max retries exceeded for code exchange");
  }
  
  pm.sendRequest({
    url: "https://www.googleapis.com/oauth2/v4/token",
    method: "POST",
    qs: {
      code: code,
      client_id: pm.variables.get("client_id"),
      client_secret: pm.variables.get("client_secret"),
      redirect_uri: pm.variables.get("redirect_uri"),
      grant_type: "authorization_code"
    }
  }, function(err, response) {
    if (response.code === 400 && response.json().error === "invalid_grant") {
      retryCount++;
      console.log(`Retry ${retryCount}/${maxRetries} for code exchange`);
      exchangeCodeWithRetry(code);
    } else {
      // Process successful response
    }
  });
}

